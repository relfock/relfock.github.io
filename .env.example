# Gemini API key for PDF import (get one at https://aistudio.google.com/app/apikey)
#
# Option A — .env (copy this file to .env and set):
#   VITE_GEMINI_API_KEY=your_key
#
# Option B — Terminal env (dev only): set GEMINI_API_KEY or GOOGLE_API_KEY
# so the Vite proxy can use it (e.g. in Cursor Settings > Terminal >
# terminal.integrated.env.linux).
VITE_GEMINI_API_KEY=

# Anthropic API key for PDF/image import when using Claude (get one at https://console.anthropic.com)
# One line, no quotes, no space after = (e.g. VITE_ANTHROPIC_API_KEY=sk-ant-api03-...). Restart dev server after editing.
# In dev the proxy also reads ANTHROPIC_API_KEY if set in your shell.
VITE_ANTHROPIC_API_KEY=

# OpenAI API key for image import when using OpenAI (get one at https://platform.openai.com/api-keys)
# OpenAI supports images only (no PDF); use Gemini or Claude for PDF. In dev the proxy can use OPENAI_API_KEY.
VITE_OPENAI_API_KEY=

# Groq API key for PDF/image import when using Groq (Llama vision; get one at https://console.groq.com)
# Free tier. In dev the proxy can use GROQ_API_KEY. PDFs are converted to images (max 5 pages).
VITE_GROQ_API_KEY=

# Google Drive sync (optional). When set, app asks to sign in with Google and stores all data + API keys in your Drive.
# 1. Create a project at https://console.cloud.google.com
# 2. Enable "Google Drive API"
# 3. Create OAuth 2.0 Client ID (Web application), add your origin (e.g. http://localhost:5173) to authorized JavaScript origins
# 4. Copy the Client ID here. No Client Secret needed (token flow is client-side).
VITE_GOOGLE_CLIENT_ID=

# Optional: local Llama via Ollama (chat only). Install: https://ollama.com then run e.g. ollama pull llama3.2
# VITE_OLLAMA_BASE_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=llama3.2

# Optional: base URL of a server that exposes POST /api/fetch-url { url } → { text } | { error }
# so chat can read linked pages (static GitHub Pages cannot proxy arbitrary URLs).
# VITE_API_BASE=https://your-backend.example.com

# WHOOP (Fitness tab): OAuth Client ID from https://developer.whoop.com/ — register Redirect URL(s) that exactly
# match what the app sends (Settings → API keys & WHOOP shows the effective URI). Optional secret if token
# exchange requires it (stored in browser / backup; not for public repos).
# VITE_WHOOP_CLIENT_ID=
# VITE_WHOOP_CLIENT_SECRET=
#
# GitHub Pages **user/org site** at domain root: the app uses https://YOURUSER.github.io (no trailing slash).
# Register that exact string in WHOOP (you can add a second URL with a trailing slash if WHOOP allows two).
# Project pages: https://YOURUSER.github.io/REPO/ — include the path and trailing slash as deployed.
# VITE_WHOOP_REDIRECT_URI=
#
# Dev: .env.development sets VITE_WHOOP_API_PROXY=/api/whoop so Vite proxies WHOOP (CORS).
#
# GitHub Pages / static hosting: browsers block direct fetch() to api.prod.whoop.com (CORS). Deploy the
# Cloudflare Worker in workers/whoop-proxy.js, then either paste the Worker URL in the app
# (Settings → API keys & WHOOP → WHOOP API proxy) or set at build time:
#   VITE_WHOOP_API_PROXY=https://whoop-proxy.YOUR_SUBDOMAIN.workers.dev
# For CI: add the same value as repo Secret VITE_WHOOP_API_PROXY (Settings → Secrets → Actions).
# VITE_WHOOP_API_PROXY=
